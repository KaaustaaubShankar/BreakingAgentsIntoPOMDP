import heapq
from collections import defaultdict
import math

def agent_step(state, history):
    def heuristic(a, b):
        return abs(a[0] - b[0]) + abs(a[1] - b[1])
    
    def a_star_search(start, goal, obstacles, max_depth=10):
        frontier = []
        heapq.heappush(frontier, (0, start))
        came_from = {}
        cost_so_far = {}
        came_from[start] = None
        cost_so_far[start] = 0
        
        while frontier:
            current_cost, current = heapq.heappop(frontier)
            
            if current == goal:
                break
            
            if cost_so_far[current] >= max_depth:
                continue
            
            for dx, dy in [(-3, 0), (3, 0), (0, -3), (0, 3)]:  # Left, Right, Up, Down
                next_step = (current[0] + dx, current[1] + dy)
                if next_step in obstacles:
                    continue
                new_cost = cost_so_far[current] + 1
                if next_step not in cost_so_far or new_cost < cost_so_far[next_step]:
                    cost_so_far[next_step] = new_cost
                    priority = new_cost + heuristic(goal, next_step)
                    heapq.heappush(frontier, (priority, next_step))
                    came_from[next_step] = current
        
        if goal not in came_from:
            return None  # No path found
        current = goal
        path = []
        while current != start:
            path.append(current)
            current = came_from[current]
        path.reverse()
        return path
    
    def get_move_direction(from_pos, to_pos):
        if from_pos[0] < to_pos[0]:
            return "MOVE_RIGHT"
        elif from_pos[0] > to_pos[0]:
            return "MOVE_LEFT"
        elif from_pos[1] < to_pos[1]:
            return "MOVE_DOWN"
        elif from_pos[1] > to_pos[1]:
            return "MOVE_UP"
        return None
    
    def analyze_history(history):
        success_counts = defaultdict(float)
        failure_counts = defaultdict(float)
        known_obstacles = set()
        consecutive_stuck = 0
        weight = 1.0  # Start with weight for most recent
        for turn in reversed(history[-20:]):  # Analyze last 20 turns
            action = turn["action"].get("action")
            if action in ["MOVE_RIGHT", "MOVE_LEFT", "MOVE_UP", "MOVE_DOWN"]:
                if not turn["moved"]:
                    failure_counts[action] += weight
                    prev_pos = tuple(turn["state"]["player"]["position"])
                    if action == "MOVE_RIGHT":
                        known_obstacles.add((prev_pos[0] + 3, prev_pos[1]))
                    elif action == "MOVE_LEFT":
                        known_obstacles.add((prev_pos[0] - 3, prev_pos[1]))
                    elif action == "MOVE_UP":
                        known_obstacles.add((prev_pos[0], prev_pos[1] - 3))
                    elif action == "MOVE_DOWN":
                        known_obstacles.add((prev_pos[0], prev_pos[1] + 3))
                    consecutive_stuck += 1
                else:
                    success_counts[action] += weight
                    consecutive_stuck = 0
                weight *= 0.8  # Decay for older turns
        return success_counts, failure_counts, known_obstacles, consecutive_stuck
    
    def should_probe(history, direction):
        # Probe if direction has mixed history and not recently failed excessively
        failed_recently = sum(1 for turn in history[-5:] if turn["action"].get("action") == direction and not turn["moved"])
        return failed_recently < 3 and success_counts.get(direction, 0) > 0 and failure_counts.get(direction, 0) > 0
    
    player_pos = tuple(state["player"]["position"])
    goals = state["objects"]["goals"]
    walls = {tuple(wall["position"]) for wall in state["objects"]["walls"]}
    blocks = {tuple(block["position"]) for block in state["objects"]["blocks"]}
    
    success_counts, failure_counts, known_obstacles, consecutive_stuck = analyze_history(history)
    obstacles = walls.union(blocks).union(known_obstacles)
    
    # Add heuristic hints
    if state["movement"].get("right_blocked", False):
        obstacles.add((player_pos[0] + 3, player_pos[1]))
    if state["movement"].get("left_blocked", False):
        obstacles.add((player_pos[0] - 3, player_pos[1]))
    if state["movement"].get("up_blocked", False):
        obstacles.add((player_pos[0], player_pos[1] - 3))
    if state["movement"].get("down_blocked", False):
        obstacles.add((player_pos[0], player_pos[1] + 3))
    
    if goals and state["resources"]["steps_remaining"] > 0:
        goal_pos = tuple(min(goals, key=lambda g: heuristic(player_pos, tuple(g["position"])))["position"])
        path = a_star_search(player_pos, goal_pos, obstacles, max_depth=state["resources"]["steps_remaining"] // 2)
        
        if path:
            next_step = path[0]
            move_direction = get_move_direction(player_pos, next_step)
            net_score = success_counts.get(move_direction, 0) - failure_counts.get(move_direction, 0)
            if net_score > 0 or should_probe(history, move_direction):
                return {"action": move_direction}
        
        # Fallback to best net success direction
        net_success = {dir: success_counts[dir] - failure_counts[dir] for dir in success_counts}
        if net_success:
            best_direction = max(net_success, key=net_success.get)
            if net_success[best_direction] > 0:
                return {"action": best_direction}
    
    if consecutive_stuck >= 3 or not path:
        selectables = [s for s in state["objects"]["selectables"] if tuple(s["position"]) != player_pos]
        if selectables:
            def selectable_score(sel):
                pos = tuple(sel["position"])
                dist_to_goal = min(heuristic(pos, tuple(g["position"])) for g in goals) if goals else float('inf')
                success_for_sel = sum(1 for turn in history if turn["action"].get("target_position") == list(pos) and turn["moved"])
                return dist_to_goal - success_for_sel  # Lower score is better
            best_selectable = min(selectables, key=selectable_score)
            return {"action": "CLICK", "target_position": best_selectable["position"]}
    
    cycle = ["MOVE_RIGHT", "MOVE_DOWN", "MOVE_LEFT", "MOVE_UP"]
    step = len(history)
    return {"action": cycle[step % len(cycle)]}