import heapq
from collections import defaultdict
import math

def agent_step(state, history):
    def heuristic(a, b):
        return abs(a[0] - b[0]) + abs(a[1] - b[1])
    
    def a_star_search(start, goal, obstacles):
        frontier = []
        heapq.heappush(frontier, (0, start))
        came_from = {}
        cost_so_far = {}
        came_from[start] = None
        cost_so_far[start] = 0
        
        while frontier:
            _, current = heapq.heappop(frontier)
            
            if current == goal:
                break
            
            for dx, dy in [(-3, 0), (3, 0), (0, -3), (0, 3)]:
                next_step = (current[0] + dx, current[1] + dy)
                if next_step not in obstacles:
                    new_cost = cost_so_far[current] + 1
                    if next_step not in cost_so_far or new_cost < cost_so_far[next_step]:
                        cost_so_far[next_step] = new_cost
                        priority = new_cost + heuristic(goal, next_step)
                        heapq.heappush(frontier, (priority, next_step))
                        came_from[next_step] = current
        
        if goal not in came_from:
            return None
        current = goal
        path = []
        while current != start:
            path.append(current)
            current = came_from[current]
        path.reverse()
        return path
    
    def get_move_direction(from_pos, to_pos):
        if from_pos[0] < to_pos[0]:
            return "MOVE_RIGHT"
        elif from_pos[0] > to_pos[0]:
            return "MOVE_LEFT"
        elif from_pos[1] < to_pos[1]:
            return "MOVE_DOWN"
        elif from_pos[1] > to_pos[1]:
            return "MOVE_UP"
        return None
    
    def analyze_history(history):
        failure_counts = defaultdict(int)
        success_counts = defaultdict(int)
        successful_sequences = defaultdict(int)  # Track sequences of successful moves
        ineffective_positions = set()  # Positions that consistently fail
        consecutive_stuck = 0
        for turn in history:
            action = turn["action"].get("action")
            if action in ["MOVE_LEFT", "MOVE_RIGHT", "MOVE_UP", "MOVE_DOWN"]:
                if turn.get("moved", False):
                    success_counts[action] += 1
                    # Track sequences: Increment if previous was successful
                    if len(history) > 1 and history[-2]["moved"]:
                        successful_sequences[action] += 1
                    consecutive_stuck = 0
                else:
                    failure_counts[action] += 1
                    consecutive_stuck += 1
                    # Add to ineffective positions based on action
                    if action == "MOVE_RIGHT":
                        ineffective_positions.add((state["player"]["position"][0] + 3, state["player"]["position"][1]))
                    elif action == "MOVE_LEFT":
                        ineffective_positions.add((state["player"]["position"][0] - 3, state["player"]["position"][1]))
                    elif action == "MOVE_UP":
                        ineffective_positions.add((state["player"]["position"][0], state["player"]["position"][1] - 3))
                    elif action == "MOVE_DOWN":
                        ineffective_positions.add((state["player"]["position"][0], state["player"]["position"][1] + 3))
        return failure_counts, success_counts, successful_sequences, ineffective_positions, consecutive_stuck
    
    player_pos = tuple(state["player"]["position"])
    goals = state["objects"]["goals"]
    walls = {tuple(wall["position"]) for wall in state["objects"]["walls"]}
    blocks = {tuple(block["position"]) for block in state["objects"]["blocks"]}
    
    # Build dynamic obstacles
    failure_counts, success_counts, successful_sequences, ineffective_positions, consecutive_stuck = analyze_history(history)
    obstacles = walls.union(blocks).union(ineffective_positions)  # Include learned ineffective positions
    if state["movement"].get("right_blocked", False):
        obstacles.add((player_pos[0] + 3, player_pos[1]))
    if state["movement"].get("left_blocked", False):
        obstacles.add((player_pos[0] - 3, player_pos[1]))
    if state["movement"].get("up_blocked", False):
        obstacles.add((player_pos[0], player_pos[1] - 3))
    if state["movement"].get("down_blocked", False):
        obstacles.add((player_pos[0], player_pos[1] + 3))
    
    if goals and state["resources"]["steps_remaining"] > 10:  # Be conservative near budget end
        # Prioritize goals based on distance and successful sequences
        goal_pos = min(goals, key=lambda g: (heuristic(player_pos, tuple(g["position"])), -successful_sequences.get(get_move_direction(player_pos, tuple(g["position"])), 0)))["position"]
        goal_pos = tuple(goal_pos)
        path = a_star_search(player_pos, goal_pos, obstacles)
        
        if path:
            next_step = path[0]
            move_direction = get_move_direction(player_pos, next_step)
            return {"action": move_direction}
        
        # If no path, probe based on least failed direction
        if failure_counts:
            least_failed_direction = min(failure_counts, key=failure_counts.get)
            return {"action": least_failed_direction}
    
    if consecutive_stuck >= 3 or not goals:
        selectables = state["objects"]["selectables"]
        other_selectables = [s for s in selectables if tuple(s["position"]) != player_pos]
        if other_selectables and goals:
            # Switch to selectable with best path to goal, considering success history
            best_selectable = min(other_selectables, key=lambda s: (heuristic(tuple(s["position"]), tuple(goals[0]["position"])), -sum(success_counts.values())))
            return {"action": "CLICK", "target_position": best_selectable["position"]}
    
    # Fallback: Choose direction with highest success or from successful sequences
    possible_actions = ["MOVE_RIGHT", "MOVE_DOWN", "MOVE_LEFT", "MOVE_UP"]
    if successful_sequences:
        best_action = max(possible_actions, key=lambda action: successful_sequences.get(action, 0))
        if successful_sequences.get(best_action, 0) > 0:
            return {"action": best_action}
    elif success_counts:
        best_action = max(possible_actions, key=lambda action: success_counts.get(action, 0))
        return {"action": best_action}
    
    # Ultimate fallback
    cycle = ["MOVE_RIGHT", "MOVE_DOWN", "MOVE_LEFT", "MOVE_UP"]
    step = len(history)
    return {"action": cycle[step % len(cycle)]}